{{ 'component-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-custom-collection-carousel.css' | asset_url | stylesheet_tag }}

<section class="collection-grid section-padding--lg-bottom">
  <div class="container-xl g-4">
    <h1 class="collection-grid__title heading-style-h2">{{ collection.title }}</h1>

    <div class="collection-grid__products">
      {% paginate collection.products by 20 %}
        {% for product in collection.products %}
          {% render 'custom-product-card', product: product %}
        {% endfor %}

        {{ paginate | default_pagination }}
      {% endpaginate %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
